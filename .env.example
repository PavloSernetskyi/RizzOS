# ElevenLabs Agent — required for voice
# Create an Agent at https://elevenlabs.io/app/conversational-ai and copy its Agent ID.
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=

# Optional: only set if your Agent is private.
# When set, the client will call /api/eleven/signed-url to mint a signed URL
# using your server-side API key (recommended for private agents).
ELEVENLABS_API_KEY=
