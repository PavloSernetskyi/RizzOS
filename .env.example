# ─── RizzOS 2.0 — Azure Speech + Groq ────────────────────────────────

# Azure Speech (STT + TTS). Server-only — never shipped to the browser.
# Browser fetches a short-lived token from /api/azure/token instead.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# Groq (LLM brain). Server-only.
GROQ_API_KEY=

# Optional: in-browser latency overlay (STT/LLM/TTS timing) when set to 1.
# Voice Lab (voice audition) only appears with 1 and `npm run dev` — never on
# Vercel, because that UI is dev-only.
NEXT_PUBLIC_RIZZ_DEBUG=0
