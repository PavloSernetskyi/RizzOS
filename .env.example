# ─── RizzOS 2.0 — Azure Speech + Groq ────────────────────────────────

# Azure Speech (STT + TTS). Server-only — never shipped to the browser.
# Browser fetches a short-lived token from /api/azure/token instead.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# Groq (LLM brain). Server-only.
GROQ_API_KEY=

# Optional: enable in-browser latency overlay during development.
# Shows STT / LLM / TTS timing in the bottom-right corner.
NEXT_PUBLIC_RIZZ_DEBUG=0
